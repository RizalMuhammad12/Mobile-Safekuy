<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_saldo_card"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SafeKuy Quick Add"
        android:textColor="@color/emerald_600"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tekan untuk mencatat transaksi baru secara manual atau AI."
        android:textColor="@color/slate_500"
        android:textSize="11sp"
        android:textAlignment="center"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnWidgetAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+ Catat Transaksi"
        android:textColor="@color/white"
        android:backgroundTint="@color/emerald_500" />

</LinearLayout>
